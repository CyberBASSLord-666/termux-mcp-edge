{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CyberBASSLord-666/termux-mcp-edge/blob/main/docs/android-volume-control-emulated-evidence-schema-v1.json",
  "title": "Termux MCP Android volume control native emulation evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "gateVersion",
    "status",
    "failureCode",
    "releaseQualificationEligible",
    "startedAt",
    "completedAt",
    "candidate",
    "environment",
    "validation"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "gateVersion": { "const": "1" },
    "status": { "const": "pass" },
    "failureCode": { "type": "null" },
    "releaseQualificationEligible": { "const": false },
    "startedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "candidate": { "$ref": "#/$defs/candidate" },
    "environment": { "$ref": "#/$defs/environment" },
    "validation": { "$ref": "#/$defs/validation" }
  },
  "$defs": {
    "sha1": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "runId": { "type": "string", "pattern": "^[1-9][0-9]*$" },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "bytes"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 1, "maximum": 67108864 }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commit",
        "version",
        "ciRunId",
        "securityRunId",
        "androidRunId",
        "artifact",
        "incompatibleArtifact"
      ],
      "properties": {
        "commit": { "$ref": "#/$defs/sha1" },
        "version": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
        },
        "ciRunId": { "$ref": "#/$defs/runId" },
        "securityRunId": { "$ref": "#/$defs/runId" },
        "androidRunId": { "$ref": "#/$defs/runId" },
        "artifact": { "$ref": "#/$defs/artifact" },
        "incompatibleArtifact": { "$ref": "#/$defs/artifact" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "architecture",
        "executionMode",
        "image",
        "imageDigest",
        "androidLinker"
      ],
      "properties": {
        "architecture": { "enum": ["aarch64", "arm64"] },
        "executionMode": { "const": "official-termux-docker-native-arm64" },
        "image": { "const": "termux/termux-docker:aarch64" },
        "imageDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "androidLinker": { "const": true }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "requests",
        "exactArtifact",
        "compileGate",
        "runtimeDefaultDisabled",
        "disabledDiscovery",
        "staticTokenRequired",
        "capabilityKeyRequired",
        "closedInputSchema",
        "previewNoMutation",
        "previewDoesNotConsumeGrant",
        "headerContextEnforced",
        "exactGrantBinding",
        "singleUseReplay",
        "freshMaximum",
        "fixedProgram",
        "exactTwoArguments",
        "fixedWorkingDirectory",
        "inheritedEnvironmentCleared",
        "nullStdin",
        "nonQueueingConcurrency",
        "mutationVerified",
        "rollbackConfirmed",
        "rollbackUnconfirmed",
        "cancellationIndependentRecovery",
        "boundedSupervisor",
        "auditCounters",
        "redactedResponses",
        "arbitraryCommandExecutionDisabled",
        "broaderAndroidControlDisabled",
        "longObservationRequired"
      ],
      "properties": {
        "status": { "const": "pass" },
        "requests": { "type": "integer", "minimum": 20 },
        "exactArtifact": { "const": true },
        "compileGate": { "const": true },
        "runtimeDefaultDisabled": { "const": true },
        "disabledDiscovery": { "const": true },
        "staticTokenRequired": { "const": true },
        "capabilityKeyRequired": { "const": true },
        "closedInputSchema": { "const": true },
        "previewNoMutation": { "const": true },
        "previewDoesNotConsumeGrant": { "const": true },
        "headerContextEnforced": { "const": true },
        "exactGrantBinding": { "const": true },
        "singleUseReplay": { "const": true },
        "freshMaximum": { "const": true },
        "fixedProgram": { "const": true },
        "exactTwoArguments": { "const": true },
        "fixedWorkingDirectory": { "const": true },
        "inheritedEnvironmentCleared": { "const": true },
        "nullStdin": { "const": true },
        "nonQueueingConcurrency": { "const": true },
        "mutationVerified": { "const": true },
        "rollbackConfirmed": { "const": true },
        "rollbackUnconfirmed": { "const": true },
        "cancellationIndependentRecovery": { "const": true },
        "boundedSupervisor": { "const": true },
        "auditCounters": { "const": true },
        "redactedResponses": { "const": true },
        "arbitraryCommandExecutionDisabled": { "const": true },
        "broaderAndroidControlDisabled": { "const": true },
        "longObservationRequired": { "const": false }
      }
    }
  }
}
