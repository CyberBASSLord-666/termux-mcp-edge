{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CyberBASSLord-666/termux-mcp-edge/blob/main/docs/release-observation-requirement-schema-v1.json",
  "title": "Termux MCP release observation requirement classification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "classifierVersion",
    "status",
    "failureCode",
    "releaseQualificationEligible",
    "createdAt",
    "evidenceMode",
    "reasonCode",
    "inheritanceCandidate",
    "source",
    "candidate",
    "emulation",
    "protectedInputComparison",
    "changedInputClasses",
    "nextGate"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "classifierVersion": { "const": "1" },
    "status": { "const": "pass" },
    "failureCode": { "type": "null" },
    "releaseQualificationEligible": { "const": false },
    "createdAt": { "type": "string", "format": "date-time" },
    "evidenceMode": {
      "enum": [
        "observation_inheritance_candidate",
        "physical_observation_required"
      ]
    },
    "reasonCode": {
      "enum": [
        "inheritance_verification_required",
        "runtime_or_deployment_inputs_changed",
        "cargo_or_dependency_inputs_changed",
        "runtime_and_build_inputs_changed"
      ]
    },
    "inheritanceCandidate": { "type": "boolean" },
    "source": { "$ref": "#/$defs/source" },
    "candidate": { "$ref": "#/$defs/candidate" },
    "emulation": { "$ref": "#/$defs/emulation" },
    "protectedInputComparison": { "$ref": "#/$defs/protectedInputComparison" },
    "changedInputClasses": {
      "type": "array",
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "enum": ["runtime_or_deployment", "cargo_or_dependency"]
      }
    },
    "nextGate": {
      "enum": [
        "observation_inheritance_verification",
        "direct_physical_device_observation"
      ]
    }
  },
  "$defs": {
    "sha1": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "runId": {
      "type": "string",
      "pattern": "^[1-9][0-9]*$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit"],
      "properties": {
        "commit": { "$ref": "#/$defs/sha1" }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commit",
        "version",
        "ciRunId",
        "securityRunId",
        "androidRunId"
      ],
      "properties": {
        "commit": { "$ref": "#/$defs/sha1" },
        "version": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
        },
        "ciRunId": { "$ref": "#/$defs/runId" },
        "securityRunId": { "$ref": "#/$defs/runId" },
        "androidRunId": { "$ref": "#/$defs/runId" }
      }
    },
    "emulation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reportSha256",
        "executionMode",
        "imageDigest",
        "status",
        "samples"
      ],
      "properties": {
        "reportSha256": { "$ref": "#/$defs/sha256" },
        "executionMode": {
          "const": "official-termux-docker-native-arm64"
        },
        "imageDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "status": { "const": "pass" },
        "samples": { "type": "integer", "minimum": 32 }
      }
    },
    "protectedInputComparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtimeAndDeploymentInputsUnchanged",
        "cargoAndDependencyInputsUnchangedExceptRootVersion"
      ],
      "properties": {
        "runtimeAndDeploymentInputsUnchanged": { "type": "boolean" },
        "cargoAndDependencyInputsUnchangedExceptRootVersion": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "inheritanceCandidate": { "const": true } },
        "required": ["inheritanceCandidate"]
      },
      "then": {
        "properties": {
          "evidenceMode": { "const": "observation_inheritance_candidate" },
          "reasonCode": { "const": "inheritance_verification_required" },
          "changedInputClasses": { "type": "array", "maxItems": 0 },
          "nextGate": { "const": "observation_inheritance_verification" },
          "protectedInputComparison": {
            "type": "object",
            "properties": {
              "runtimeAndDeploymentInputsUnchanged": { "const": true },
              "cargoAndDependencyInputsUnchangedExceptRootVersion": {
                "const": true
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "evidenceMode": { "const": "physical_observation_required" },
          "changedInputClasses": { "type": "array", "minItems": 1 },
          "nextGate": { "const": "direct_physical_device_observation" }
        }
      }
    }
  ]
}
